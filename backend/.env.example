PORT=5000
NODE_ENV=development

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Opcional, mas recomendado para separar auth publico de operacoes admin.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

FRONTEND_URL=http://localhost:5173
SERVE_STATIC_FRONTEND=false

# SMTP recomendado para cloud: prefira porta 587 com STARTTLS e IPv4.
SMTP_HOST=smtp.seu-provedor.com
SMTP_PORT=587
SMTP_USER=contato@syncho.cloud
SMTP_PASS=sua-app-password-ou-senha-smtp
SMTP_FROM=contato@syncho.cloud
SMTP_FROM_NAME=Syncho Cloud

# E-mail que recebe solicitacoes de suporte abertas por clientes.
SUPPORT_NOTIFY_EMAIL=contato@syncho.cloud
